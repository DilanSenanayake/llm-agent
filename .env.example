# Google Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Optional: LangChain/Google stacks often accept this name instead
# GOOGLE_API_KEY=

# Optional: override default Gemini model (Google Gen AI SDK)
# GEMINI_MODEL=gemini-3-flash-preview

# Optional: cache directory for sentence-transformers models
# SENTENCE_TRANSFORMERS_HOME=
